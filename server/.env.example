# ============================================================
# CodeSync Server — .env Template (safe to commit)
# Copy to .env and fill in real values. Never commit the real .env.
# ============================================================

PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Dedicated MongoDB Atlas cluster for CodeSync (separate from other projects)
MONGODB_URI=mongodb+srv://<username>:<password>@<codesync-cluster>.mongodb.net/codesync_db?retryWrites=true&w=majority

JWT_SECRET=<64-char random hex>
JWT_EXPIRES_IN=7d
SESSION_SECRET=<32-char random string>

GOOGLE_CLIENT_ID=<from Google Cloud Console, new OAuth client for CodeSync>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Room defaults
DEFAULT_ROOM_TTL_HOURS=24

# Code execution sandbox (self-hosted vm timeout by default; swap for a hosted
# provider like Judge0/Piston in production by setting CODE_EXEC_PROVIDER)
CODE_EXEC_PROVIDER=local
CODE_EXEC_TIMEOUT_MS=3000
